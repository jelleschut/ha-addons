@inject WeatherApiClient Api

<MudCard Elevation="2" Class="mb-3" Style="border-radius: 16px; overflow: hidden;">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h6">@Location.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Location.City</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <OpeningBadge Opening="@Location.TodayOpening"/>
                    <FavoriteButton LocationId="@Location.Id" OnChanged="OnFavoriteChanged"/>
                </div>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2"/>
            <MudSkeleton Height="60px"/>
        }
        else if (_error)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">Weer kon niet worden geladen</MudAlert>
        }
        else
        {
            <WeatherSummary Weather="@(_weather?.TodayOpeningWeather ?? _weather?.Current)"/>
            <div class="mt-2 d-flex align-center gap-3">
                @if (_todayScore.HasValue)
                {
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Vandaag:</MudText>
                        <WakeScoreBadge Score="_todayScore"/>
                    </div>
                }
                @if (_bestForecastDay is var (bestDay, bestLabel) && bestDay.Date != DateOnly.FromDateTime(DateTime.Today))
                {
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Beste dag:</MudText>
                        <MudText Typo="Typo.caption">@bestLabel</MudText>
                        <WakeScoreBadge Score="bestDay.WakeScore"/>
                    </div>
                }
            </div>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@($"/locatie/{Location.Slug}")" EndIcon="@Icons.Material.Filled.ChevronRight">
            14-daagse voorspelling
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired] public LocationSummaryDto Location { get; set; } = null!;
    [Parameter] public EventCallback OnFavoriteChanged { get; set; }

    private WeatherResponse? _weather;
    private bool _loading = true;
    private bool _error;

    private double? _todayScore =>
        _weather?.Forecast.FirstOrDefault(f => f.Date == DateOnly.FromDateTime(DateTime.Today))?.WakeScore
        ?? _weather?.CurrentScore;

    private (ForecastDayDto Day, string Label)? _bestForecastDay
    {
        get
        {
            var best = _weather?.Forecast.Where(f => f.WakeScore.HasValue).MaxBy(f => f.WakeScore);
            if (best is null) return null;
            var today = DateOnly.FromDateTime(DateTime.Today);
            var label = (best.Date.DayNumber - today.DayNumber) switch
            {
                0 => "Vandaag",
                1 => "Morgen",
                _ => best.Date.ToString("ddd d MMM", new System.Globalization.CultureInfo("nl-NL"))
            };
            return (best, label);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _weather = await Api.GetWeatherAsync(Location.Slug);
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _loading = false;
        }
    }
}
