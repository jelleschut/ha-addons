@inherits LayoutComponentBase

<MudThemeProvider/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Fixed="true">
        <MudText Typo="Typo.h6" Class="ml-2">WakeWeather</MudText>
        <MudSpacer/>
        <MudIconButton Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Inherit" Href="/"/>
    </MudAppBar>
    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
